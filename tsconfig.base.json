{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@shop/shared-types": ["./packages/shared-types/src"],
      "@shop/shared-types/*": ["./packages/shared-types/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".pnpm-store"]
}
